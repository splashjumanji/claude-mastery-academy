# ─── Content Flags ───────────────────────────────────────────────────────────
# Slack incoming webhook — flags submitted by reviewers post here
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Content Evolution Sweep (weekly cron) ───────────────────────────────────
# Tavily API key — powers web search (free tier, no credit card)
# Get at: https://app.tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Anthropic API key — Claude synthesises findings into the gap report
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Vercel injects CRON_SECRET automatically — no action needed

# ─── Content Review Dashboard ─────────────────────────────────────────────────
# GitHub Personal Access Token with repo scope — used by Vercel functions to
# read/write proposals.json and apply approved changes to modules.js.
# Create at: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub repo in owner/name format
GITHUB_REPO=your-username/aisv-academy

# Passphrase to access the /review admin page.
# Also add this to Vercel as VITE_REVIEW_KEY so it is baked into the frontend build.
VITE_REVIEW_KEY=your-review-passphrase
